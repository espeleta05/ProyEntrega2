# .env.example â€” variables de entorno para desarrollo
# Copia este archivo a `.env` y rellena los valores sensibles.

# Seguridad
SECRET_KEY=replace-with-a-secret

# Motor de base de datos: postgres o mariadb
DB_ENGINE=postgres

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=mi_usuario
PG_PASSWORD=625122
PG_DB=sistemavacunacion

# MariaDB (si usas MySQL/MariaDB)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=sistemavacunacion
